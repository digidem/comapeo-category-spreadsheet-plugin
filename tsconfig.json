{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2020",
    "module": "none",
    "lib": ["es2020"],
    "types": ["google-apps-script"],
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "useUnknownInCatchVariables": false
  },
  "include": ["index.ts", "src/**/*.ts"],
  "exclude": [
    "package/**",
    "plans/**",
    "src/scripts/**",
    "src/test/testBuildAndImport.ts",
    "src/test/testDetailsAndIcons.ts",
    "src/test/testEndToEnd.ts",
    "src/test/testExtractAndValidate.ts",
    "src/test/testFieldExtraction.ts",
    "src/test/testHelpers.ts",
    "src/test/testRow2Translation.ts",
    "src/test/testRunner.ts",
    "src/test/testSkipTranslation.ts",
    "src/test/testZipToApi.ts",
    "src/test/translationExtractor.ts",
    "src/test/testTranslationExtraction.ts"
  ]
}
